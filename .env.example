# =====================================================================
# X Intelligence & Content Automation Skills — Environment Template
# =====================================================================
# このファイルを `.env` にコピーし、必要な値を埋めて使用してください。
# `.env` は git 管理外です（.gitignore で除外済み）。
# =====================================================================

# --- Provider Selection ---------------------------------------------
# X 検索の Provider を切替。MVP では mock を既定推奨。
# 選択肢: mock | hermes | xai | x_api
X_SEARCH_PROVIDER=mock

# LLM Provider を切替。API key 未設定なら自動で mock fallback。
# 選択肢: mock | claude | grok
LLM_PROVIDER=mock

# --- xAI / Grok -----------------------------------------------------
XAI_API_KEY=
GROK_PROVIDER=xai            # xai | hermes
GROK_MODEL=grok-4            # 推奨現行モデル。最新は README 参照
GROK_IMAGE_MODEL=grok-2-image
GROK_VIDEO_MODEL=grok-imagine

# --- Hermes Agent ---------------------------------------------------
HERMES_ENABLED=false
HERMES_OAUTH_TOKEN=
HERMES_X_SEARCH_ENABLED=false
HERMES_IMAGE_GEN_ENABLED=false
HERMES_VIDEO_GEN_ENABLED=false

# --- Anthropic (Claude) ---------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7   # MVP 既定。要約・スコアリング用

# --- X API v2 (将来) ------------------------------------------------
X_SEARCH_ENABLED=false
X_API_BEARER_TOKEN=

# --- Grok Imagine (画像/動画生成) ----------------------------------
GROK_IMAGINE_ENABLED=false     # MVP では prompt 生成までで停止
GROK_IMAGINE_API_KEY=

# --- Misc -----------------------------------------------------------
TIMEZONE=Asia/Bangkok          # 柴田さんタイ滞在中。帰国後は Asia/Tokyo
DEFAULT_TIME_RANGE=24h         # 24h | 3d | 7d
LOG_LEVEL=INFO
